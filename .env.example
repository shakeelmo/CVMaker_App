# CV Maker - Environment Configuration
# Copy this file to .env one level above public_html, or set the same variables
# in your hosting control panel.

# Database
DB_HOST=localhost
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# Security
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# PayPal
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET

# Gemini AI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# SMTP (optional - can be configured in admin dashboard)
SMTP_HOST=YOUR_SMTP_HOST
SMTP_PORT=587
SMTP_USERNAME=YOUR_SMTP_USERNAME
SMTP_PASSWORD=YOUR_SMTP_PASSWORD

# License validation
LICENSE_API_URL=https://resume.muawia.com/api/validate
LICENSE_API_SECRET=YOUR_LICENSE_API_SECRET
LICENSE_KEY=
